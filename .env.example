# Database
# For local development, use a local Postgres instance
# For Vercel deployment, these are automatically set by Vercel Postgres
# POSTGRES_URL is the pooled connection URL (used at runtime)
# DATABASE_URL is the direct connection URL (used for migrations/db push)
POSTGRES_URL="postgresql://postgres:postgres@localhost:5432/kanban?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kanban?schema=public"

# Session
SESSION_SECRET="change-this-to-a-random-string-in-production"
