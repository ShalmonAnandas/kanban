# Database
# For local development, use a local Postgres instance
# For Vercel deployment, these are automatically set by Vercel Postgres
# POSTGRES_PRISMA_URL is the pooled connection URL (used at runtime)
# POSTGRES_URL_NON_POOLING is the direct connection URL (used for migrations)
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/kanban?schema=public"
POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@localhost:5432/kanban?schema=public"

# Session
SESSION_SECRET="change-this-to-a-random-string-in-production"
