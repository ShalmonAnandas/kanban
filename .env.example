# Neon Database (Vercel auto-provides these when Neon integration is added)
# The app checks these in order: NEON_DATABASE_URL, NEON_POSTGRES_URL,
# NEON_DATABASE_URL_UNPOOLED, NEON_POSTGRES_URL_NON_POOLING, NEON_POSTGRES_URL_NO_SSL
NEON_DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Encryption key for end-to-end data encryption (any string, will be SHA-256 hashed to 32 bytes)
ENCRYPTION_KEY="change-this-to-a-random-string-in-production"

# Migration settings
# Set to 'false' to disable the migration scheduler
MIGRATION_ENABLED=true
# Secret for authenticating cron jobs (set in Vercel dashboard)
CRON_SECRET="your-cron-secret"

# Old Prisma database URL (only needed for migration scheduler)
# PRISMA_DATABASE_URL="postgresql://..."

# Vercel Blob storage for images
# BLOB_READ_WRITE_TOKEN="..."
